<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/bottomButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:layout_marginBottom="16dp">

        <!-- Row for Find + Become -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/buttonFindTutor"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/find_tutor"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/buttonBecomeTutor"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/become_tutor"
                android:textAllCaps="false" />
        </LinearLayout>

        <!-- Logout button BELOW -->
        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/logout"
            android:textAllCaps="false"
            android:backgroundTint="#D32F2F" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/mainContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomButtons"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="2dp"
            android:text="@string/welcome_username"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="@string/home_subtitle"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/linkMyProfile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:clickable="true"
            android:focusable="true"
            android:text="@string/my_profile"
            android:textColor="#0000EE"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/profileCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="#EDEDED"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:id="@+id/textProfileName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_name"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/textProfileSubjects"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_subjects"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/textProfileLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="3dp"
                android:text="@string/profile_level"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/textProfileSuggestion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_suggestion"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/linkFeaturedTutors"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:clickable="true"
            android:focusable="true"
            android:text="@string/featured_tutors"
            android:textColor="#0000EE"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/tutorCard1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:background="#F5F5F5"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:id="@+id/textTutor1Name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tutor1_name"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textTutor1Rating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tutor1_rating"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tutorCard2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="#F5F5F5"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:id="@+id/textTutor2Name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tutor2_name"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textTutor2Rating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tutor2_rating"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/linkMyTutors"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:clickable="true"
            android:focusable="true"
            android:text="@string/my_tutors"
            android:textColor="#0000EE"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textMyTutorsDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/my_tutors_description"
            android:textSize="11sp" />



    </LinearLayout>

</RelativeLayout>