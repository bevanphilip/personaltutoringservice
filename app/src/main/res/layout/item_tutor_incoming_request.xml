<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvIncomingStudent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Student: User"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvIncomingTutorName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tutor"
            android:layout_marginTop="6dp" />

        <TextView
            android:id="@+id/tvIncomingSubject"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Subject"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvIncomingAvailability"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Availability"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvIncomingPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Price"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvIncomingStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status: Pending"
            android:textStyle="bold"
            android:layout_marginTop="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <Button
                android:id="@+id/btnAcceptRequest"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Accept" />

            <Button
                android:id="@+id/btnDeclineRequest"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Decline"
                android:layout_marginStart="8dp"
                android:backgroundTint="@android:color/holo_red_dark"
                android:textColor="@android:color/white" />

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>