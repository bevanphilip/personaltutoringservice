<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F5F5">

    <TextView
        android:id="@+id/tvDetailTutorName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tutor Name:"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#666666"
        android:layout_marginBottom="10dp" />

    <TextView
        android:id="@+id/tvDetailTutorSubject"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Subject:"
        android:textSize="18sp"
        android:textColor="#666666"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/tvDetailTutorPrice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Price:"
        android:textSize="18sp"
        android:textColor="#2EAF3F"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/tvDetailTutorLocation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Location:"
        android:textSize="18sp"
        android:textColor="#666666"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/tvDetailTutorRating"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Rating:"
        android:textSize="18sp"
        android:textColor="#666666"
        android:layout_marginBottom="14dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tutor Feedback"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#666666"
        android:layout_marginBottom="8dp" />

    <!-- Only feedback scrolls now -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="false"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:id="@+id/layoutTutorFeedbackContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNoFeedback"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No feedback yet"
                android:textSize="16sp"
                android:textColor="#666666"
                android:background="#FFFFFF"
                android:padding="12dp" />
        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnBookSession"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Book a Session"
        android:textAllCaps="false"
        android:textSize="20sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#6A00F4" />

</LinearLayout>