<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <ImageButton
            android:id="@+id/btnHome"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="end"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Home"
            android:src="@drawable/baseline_home_24" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="My Profile"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="12dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <EditText
                    android:id="@+id/etProfileName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Name" />

                <EditText
                    android:id="@+id/etProfileEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Email"
                    android:inputType="textEmailAddress"
                    android:layout_marginTop="8dp" />

                <EditText
                    android:id="@+id/etProfileRole"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Role"
                    android:layout_marginTop="8dp" />

                <EditText
                    android:id="@+id/etProfilePhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Phone"
                    android:inputType="phone"
                    android:layout_marginTop="8dp" />

                <EditText
                    android:id="@+id/etProfileLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Preferred Location"
                    android:layout_marginTop="8dp" />

                <Button
                    android:id="@+id/btnSaveProfile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Save Profile"
                    android:layout_marginTop="16dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tutor Service"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvTutorServiceStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tutor services not activated yet."
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTutorServiceSubject"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Subject: --"
                    android:textSize="16sp"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/tvTutorServicePrice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Price: --"
                    android:textSize="16sp"
                    android:layout_marginTop="6dp" />

                <TextView
                    android:id="@+id/tvTutorServiceAvailability"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Availability: --"
                    android:textSize="16sp"
                    android:layout_marginTop="6dp" />

                <TextView
                    android:id="@+id/tvTutorServiceLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Location: --"
                    android:textSize="16sp"
                    android:layout_marginTop="6dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <Button
            android:id="@+id/btnEditTutorServices"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Edit / Activate Tutor Services"
            android:layout_marginTop="24dp" />

        <Button
            android:id="@+id/btnMyTutors"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="My Tutors"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btnTutorRequests"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tutor Requests"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>