<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <!-- Bottom Buttons -->
    <LinearLayout
        android:id="@+id/bottomButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:layout_marginBottom="16dp">

        <!-- Row for 2 buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/buttonActivateTutorServices"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/activateTutorServices"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/buttonTutoringRequests"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/TutoringRequests"
                android:textAllCaps="false" />
        </LinearLayout>

        <!-- Logout Button -->
        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/logout"
            android:textAllCaps="false"
            android:backgroundTint="#D32F2F"/>
    </LinearLayout>

    <!-- Main Scroll Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomButtons">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Welcome -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome, Username"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tutorHomeIntro"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp" />

            <!-- Profile -->
            <TextView
                android:id="@+id/linkMyProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile"
                android:textStyle="bold"
                android:textColor="#0000EE" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#EEEEEE"
                android:padding="12dp"
                android:text="Name: Username&#10;Tutor Skills: Not set&#10;Tutor Rating: Not set&#10;Reviews: Not set&#10;Availability: Not set"
                android:layout_marginTop="8dp" />

            <!-- Student Requests -->
            <TextView
                android:id="@+id/linkStudentRequests"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/studentRequest"
                android:textStyle="bold"
                android:textColor="#0000EE"
                android:layout_marginTop="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#EEEEEE"
                android:padding="12dp"
                android:text="@string/sessionsInfo"
                android:layout_marginTop="8dp" />

        </LinearLayout>
    </ScrollView>

</RelativeLayout>