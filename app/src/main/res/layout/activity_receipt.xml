<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Payment Receipt"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#666666"
            android:gravity="center"
            android:layout_marginTop="12dp" />

        <TextView
            android:id="@+id/tvReceiptStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Payment Successful"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#388E3C"
            android:gravity="center"
            android:layout_marginTop="24dp" />

        <TextView
            android:id="@+id/tvReceiptDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Receipt details"
            android:textSize="16sp"
            android:textColor="#666666"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginTop="24dp" />

        <Button
            android:id="@+id/btnBackToMyTutors"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Back to My History"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#6A00F4"
            android:layout_marginTop="32dp" />

    </LinearLayout>
</ScrollView>