<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5"
    android:padding="16dp">

    <TextView
        android:id="@+id/textWelcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Welcome, User"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#666666"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/linkMyProfile"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="My Profile"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#0000EE"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginBottom="6dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#EAEAEA"
        android:padding="10dp"
        android:layout_marginBottom="10dp">

        <TextView
            android:id="@+id/tvQuickName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Name: Not set"
            android:textSize="15sp"
            android:textColor="#666666" />

        <TextView
            android:id="@+id/tvQuickInterests"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Interests: Not set"
            android:textSize="15sp"
            android:textColor="#666666" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Featured Tutors"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#0000EE"
        android:layout_marginBottom="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#EAEAEA"
        android:padding="10dp"
        android:layout_marginBottom="6dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sarah M. - Math Tutor"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#666666" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rating: 4.9"
            android:textSize="13sp"
            android:textColor="#777777" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#EAEAEA"
        android:padding="10dp"
        android:layout_marginBottom="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Daniel R. - Programming Tutor"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#666666" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rating: 4.8"
            android:textSize="13sp"
            android:textColor="#777777" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="My Requests"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#0000EE"
        android:layout_marginBottom="4dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:padding="8dp">

        <LinearLayout
            android:id="@+id/layoutMyRequests"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

    </ScrollView>

    <Button
        android:id="@+id/btnStudentHistory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="My History"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#6A00F4"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/buttonFindTutor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Find a Tutor"
        android:textAllCaps="false"
        android:textSize="20sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#6A00F4"
        android:layout_marginTop="6dp" />

    <Button
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Logout"
        android:textAllCaps="false"
        android:textSize="20sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#D32F2F"
        android:layout_marginTop="6dp" />

</LinearLayout>